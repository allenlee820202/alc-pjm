# Supabase (cloud) — fill these in to enable real auth + persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AUTH_MODE=stub disables Supabase and uses an in-memory user (dev/CI only)
# AUTH_MODE=supabase uses Supabase Auth
AUTH_MODE=stub

# REPO_MODE=memory uses in-process repositories (dev/CI)
# REPO_MODE=supabase uses Supabase Postgres
REPO_MODE=memory

# Used only in stub auth mode for the seeded demo user
STUB_AUTH_EMAIL=demo@example.com
STUB_AUTH_PASSWORD=demo1234
